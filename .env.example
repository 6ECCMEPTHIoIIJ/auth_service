# Скопируйте в `.env` и подставьте свои значения.

# PostgreSQL: и образ postgres, и DATABASE_URL в контейнере auth собираются из этих полей
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=auth
# Порт внутри контейнера / в URL между сервисами (docker-compose: DATABASE_URL и справа в ports)
POSTGRES_PORT=5432
# Порт на хосте (слева в ports)
POSTGRES_PUBLISH_PORT=5432

# Redis: порты; в Docker REDIS_URL задаётся в docker-compose.yml из REDIS_PORT
REDIS_PASSWORD=
REDIS_PORT=6379
# Порт на хосте (слева в ports)
REDIS_PUBLISH_PORT=6379

JWT_SECRET=please-use-at-least-16-chars-secret
INTERNAL_API_KEY=please-use-at-least-8-chars-key

ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800